{
  "name": "storyboard",
  "version": "0.1.0",
  "private": true,
  "description": "AI-assisted operating system for bands and artists.",
  "packageManager": "pnpm@10.32.0",
  "engines": {
    "node": "22.22.x",
    "pnpm": "10.x"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --filter @storyboard/web --filter @storyboard/api dev",
    "build": "pnpm -r --if-present build",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "test:integration": "pnpm --filter @storyboard/api test:integration",
    "test:e2e": "node scripts/run-e2e.mjs",
    "infra:up": "docker compose up -d postgres redis",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f postgres redis",
    "container:up": "docker compose -f docker-compose.app.yml up --build",
    "container:down": "docker compose -f docker-compose.app.yml down",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node prisma/seed.mjs",
    "db:studio": "prisma studio",
    "db:audit-relationships": "node scripts/audit-artist-references.mjs",
    "manager:eval": "pnpm --filter @storyboard/api build && node scripts/run-manager-evals.mjs",
    "dev:web": "pnpm --filter @storyboard/web dev",
    "dev:api": "pnpm --filter @storyboard/api dev",
    "preflight": "node scripts/preflight.mjs",
    "prepare": "pnpm --filter @storyboard/shared build"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/engines",
      "@swc/core",
      "msgpackr-extract",
      "prisma",
      "sharp"
    ]
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "dotenv": "16.4.7",
    "pg": "8.14.1",
    "eslint": "9.39.4",
    "prisma": "7.6.0",
    "typescript-eslint": "8.46.2"
  }
}
