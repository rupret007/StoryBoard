# Local-demo defaults are embedded in docker-compose.app.yml. Copy this only to override them.
POSTGRES_PASSWORD=replace-with-a-local-password
SESSION_SECRET=replace-with-a-long-local-secret
SEED_OPERATOR_EMAIL=dev@localhost
SEED_OPERATOR_NAME=Local Dev
# Optional host-port overrides.
# POSTGRES_PORT=5432
# REDIS_PORT=6379
# API_PORT=4000
# WEB_PORT=3000
# These browser-facing values are compiled into the web image. Rebuild after changing them.
WEB_URL=http://localhost:3000
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# For docker-compose.production.yml, also set public HTTPS URLs and Google OAuth:
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_OPERATOR_REDIRECT_URI=https://api.example.com/auth/operator/google/callback
# Per-artist Gmail, Calendar, and Drive connections also require:
# GOOGLE_REDIRECT_URI=https://api.example.com/auth/google/callback
# INTEGRATION_SECRETS_ENCRYPTION_KEY=<32 random bytes, base64-encoded>
