# App
NODE_ENV=development
WEB_PORT=3000
API_PORT=4000
WEB_URL=http://localhost:3000
API_URL=http://localhost:4000
# Optional server-only API route (primarily for container/service networking).
INTERNAL_API_URL=
# Browser API base (defaults to API_URL in next.config via root .env)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Database
POSTGRES_DB=storyboard
POSTGRES_USER=storyboard
POSTGRES_PASSWORD=storyboard
POSTGRES_PORT=5432
DATABASE_URL=postgresql://storyboard:storyboard@localhost:5432/storyboard?schema=public

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Auth and session
SESSION_SECRET=replace-me
# Optional: set to `localhost` so the session cookie may be visible to Next.js on another port (local dev SSR).
COOKIE_DOMAIN=localhost
# Operator sign-in (Google OIDC); add this exact URI in Google Cloud Console OAuth client
GOOGLE_OPERATOR_REDIRECT_URI=http://localhost:4000/auth/operator/google/callback
# Local only: skip Google and sign in as SEED_OPERATOR_EMAIL (requires db seed + membership)
AUTH_DEV_BYPASS=false
SEED_OPERATOR_EMAIL=dev@localhost
SEED_OPERATOR_NAME=Local Dev
# Membership invite link expiry (days)
INVITE_EXPIRY_DAYS=14

# OpenAI (set OPENAI_ENABLED=true only with a real key)
OPENAI_ENABLED=false
OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-5.4
OPENAI_COMMAND_MODEL=gpt-5.4
OPENAI_SUMMARY_MODEL=gpt-5.4
# Cross-functional Manager workspace; Terra balances reasoning quality and cost.
OPENAI_MANAGER_MODEL=gpt-5.6-terra
# Booking advisor: `full` allows configured OpenAI requests to include artist CRM context.
OPENAI_ADVISOR_CONTEXT=aggregate
# Requires OPENAI_ENABLED=true; allows owners to enable the daily advisor scheduler.
BOOKING_ADVISOR_AUTOMATION_ENABLED=false
GMAIL_REPLY_SYNC_ENABLED=false
GMAIL_REPLY_SYNC_REPEAT_MS=900000

# Gmail / Google OAuth (client required for real Gmail + Calendar + Drive; see docs/integrations-google-oauth.md)
GOOGLE_CLIENT_ID=replace-me
GOOGLE_CLIENT_SECRET=replace-me
# Env fallback refresh token (optional if you use per-artist Google connection in DB)
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback
# AES-GCM key for encrypting IntegrationConnection secrets (base64 32 bytes or long passphrase derived via scrypt)
INTEGRATION_SECRETS_ENCRYPTION_KEY=
# BullMQ: set to "false" to skip registering the in-process worker (jobs can still be enqueued)
ENABLE_QUEUE_WORKER=true
# Phase 4A automation: stale follow-up threshold (days) and optional repeat interval (ms, default 6h)
WORKFLOW_STALE_FOLLOWUP_DAYS=7
# WORKFLOW_AUTOMATION_REPEAT_MS=21600000
# Phase 4B digests: optional repeat intervals (ms; defaults 1 day / 7 days)
# WORKFLOW_DIGEST_DAILY_MS=86400000
# WORKFLOW_DIGEST_WEEKLY_MS=604800000
# Phase 5A: Telegram Bot API token for urgent outbound alerts (optional; mock if unset)
# TELEGRAM_BOT_TOKEN=
# Phase 5B: inbound registration (optional)
# Bot username without @ — used to build https://t.me/<user>?start=... deep links
# TELEGRAM_BOT_USERNAME=my_storyboard_bot
# Short-lived link tokens (minutes, 5–120; default 20)
# TELEGRAM_REGISTRATION_TTL_MINUTES=20
# Optional: setWebhook secret_token; API requires matching X-Telegram-Bot-Api-Secret-Token
# TELEGRAM_WEBHOOK_SECRET=
GMAIL_PUBSUB_TOPIC=

# Google Calendar
GOOGLE_CALENDAR_DEFAULT_ID=primary

# Google Drive
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# Bandsintown (app id from https://www.bandsintown.com/api/overview — optional; mock if unset)
BANDSINTOWN_APP_ID=replace-me

# Ticketmaster Discovery API (optional; real city-first venue/event signals when set)
TICKETMASTER_API_KEY=replace-me

# YouTube
YOUTUBE_API_KEY=replace-me

# Spotify
SPOTIFY_CLIENT_ID=replace-me
SPOTIFY_CLIENT_SECRET=replace-me

# Later integrations
TIKTOK_CLIENT_ID=
MAILCHIMP_API_KEY=
TWILIO_ACCOUNT_SID=
PRINTFUL_API_KEY=
SHOPIFY_API_KEY=
STRIPE_SECRET_KEY=
DOCUMENSO_BASE_URL=
