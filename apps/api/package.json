{
  "name": "@storyboard/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "lint": "eslint -c ../../eslint.config.mjs \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "pnpm run build && node --test test/*.test.mjs",
    "test:integration": "node ../../scripts/prepare-test-database.mjs && pnpm run build && node --test test/integration/**/*.test.mjs",
    "prisma:generate": "cd ../.. && prisma generate",
    "prisma:migrate:dev": "cd ../.. && prisma migrate dev",
    "prisma:studio": "cd ../.. && prisma studio"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "11.2.0",
    "@nestjs/common": "11.1.18",
    "@nestjs/config": "4.0.3",
    "@nestjs/core": "11.1.18",
    "@nestjs/platform-fastify": "11.1.18",
    "@prisma/adapter-pg": "7.6.0",
    "@prisma/client": "7.6.0",
    "@storyboard/shared": "workspace:*",
    "bullmq": "5.73.0",
    "fastify": "5.8.4",
    "googleapis": "159.0.0",
    "ioredis": "5.10.1",
    "openai": "6.33.0",
    "pg": "8.14.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.17",
    "@nestjs/schematics": "11.0.10",
    "@nestjs/testing": "11.1.17",
    "@types/node": "25.5.0",
    "@types/pg": "8.11.11",
    "prisma": "7.6.0",
    "ts-node": "10.9.2",
    "typescript": "5.9.2"
  }
}
