generator client {
  provider = "prisma-client"
  output   = "../apps/api/src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum BookingStage {
  target
  outreach
  conversation
  offer
  hold
  confirmed
  closed
}

enum BookingProspectKind {
  venue
  festival
  private_event
  corporate_event
}

enum BookingProspectStatus {
  discovered
  qualified
  disqualified
  converted
}

enum BookingCampaignStatus {
  draft
  active
  closed
}

enum BookingMarketSprintStatus {
  draft
  active
  completed
  abandoned
}

enum BookingCampaignDeliveryMode {
  draft_only
  send_on_execution
}

enum BookingCampaignRecipientStatus {
  needs_contact
  ready
  approval_requested
  drafted
  sent
  replied
  declined
  booked
}

enum BookingCampaignDeliveryStatus {
  pending
  sending
  sent
  failed
  unknown
}

enum BookingAdvisorTrigger {
  manual
  scheduled
}

enum BookingAdvisorRecommendationOutcome {
  suggested
  accepted
  dismissed
  completed
  blocked
}

enum TaskStatus {
  todo
  in_progress
  blocked
  done
}

enum ApprovalStatus {
  proposed
  pending
  approved
  rejected
  expired
  executed
  failed
}

enum AuditSeverity {
  info
  warning
  critical
}

enum ContactKind {
  general
  promoter
  venue_staff
}

enum ArtistMembershipRole {
  owner
  member
  viewer
}

enum MembershipInviteStatus {
  pending
  accepted
  revoked
  expired
}

enum InviteDeliveryChannel {
  none
  gmail_draft
  mock
  skipped
  failed
}

enum WorkflowNotificationKind {
  invite_delivered
  approval_created
  approval_approved
  approval_rejected
  approval_executed
  approval_failed
  membership_invite_accepted
  integration_connection_changed
  task_overdue_digest
  followup_stale_digest
  digest_daily
  digest_weekly
}

model Operator {
  id          String                   @id @default(cuid())
  email       String                   @unique
  name        String?
  googleSub   String?                  @unique
  workflowEmailEnabled Boolean        @default(true)
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  memberships ArtistMembership[]
  auditEvents AuditEvent[]
  invitesCreated ArtistMembershipInvite[] @relation("InviteCreator")
  invitesAccepted ArtistMembershipInvite[] @relation("InviteAcceptor")
  workflowNotifications WorkflowNotification[]
  telegramRegistrationTokensCreated TelegramRegistrationToken[] @relation("TelegramRegistrationCreator")
  advisorFeedback BookingAdvisorFeedback[]
}

model ArtistMembership {
  id                   String               @id @default(cuid())
  operatorId           String
  artistId             String
  role                 ArtistMembershipRole @default(member)
  workflowNotifyPrefs  Json?
  createdAt            DateTime             @default(now())
  operator             Operator             @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  artist               Artist               @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@unique([operatorId, artistId])
  @@index([artistId])
}

model Artist {
  id                          String               @id @default(cuid())
  name                        String
  slug                        String               @unique
  workflowOverdueGraceDays    Int?
  workflowStaleFollowupDays   Int?
  workflowPendingApprovalDays Int?
  telegramUrgentEnabled       Boolean              @default(false)
  telegramChatId              String?
  telegramNotifyCategories    Json?
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @updatedAt
  venues        Venue[]
  contacts      Contact[]
  opportunities BookingOpportunity[]
  tasks         Task[]
  approvals     ApprovalRequest[]
  commandRuns   CommandRun[]
  integrations  IntegrationConnection[]
  memberships   ArtistMembership[]
  bookingProfile ArtistBookingProfile?
  bookingProspects BookingProspect[]
  bookingCampaigns BookingCampaign[]
  bookingMarketSprints BookingMarketSprint[]
  bookingCampaignDeliveries BookingCampaignDelivery[]
  advisorRuns             BookingAdvisorRun[]
  bookingAdvisorSettings  BookingAdvisorSettings?
  membershipInvites ArtistMembershipInvite[]
  workflowNotifications WorkflowNotification[]
  telegramUrgentDedupes TelegramUrgentDedupe[]
  telegramRegistrationTokens TelegramRegistrationToken[]
}

model BookingAdvisorRun {
  id            String   @id @default(cuid())
  artistId      String
  mode          String
  model         String?
  promptVersion String
  trigger       BookingAdvisorTrigger @default(manual)
  scheduledLocalDate String?
  inputFacts    Json
  advice        Json
  createdAt     DateTime @default(now())
  artist        Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  feedback      BookingAdvisorFeedback[]
  recommendations BookingAdvisorRecommendation[]

  @@index([artistId, createdAt])
  @@unique([artistId, trigger, scheduledLocalDate])
}

model BookingAdvisorSettings {
  id              String   @id @default(cuid())
  artistId        String   @unique
  scheduleEnabled Boolean  @default(false)
  timezone        String?
  dailyHour       Int      @default(9)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  artist          Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
}

model BookingAdvisorRecommendation {
  id          String   @id @default(cuid())
  advisorRunId String
  stableKey   String
  title       String
  priority    String
  evidence    Json
  outcome     BookingAdvisorRecommendationOutcome @default(suggested)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  advisorRun  BookingAdvisorRun @relation(fields: [advisorRunId], references: [id], onDelete: Cascade)

  @@unique([advisorRunId, stableKey])
  @@index([advisorRunId, outcome])
}

model BookingAdvisorFeedback {
  id           String   @id @default(cuid())
  advisorRunId String
  operatorId   String
  helpful      Boolean
  createdAt    DateTime @default(now())
  advisorRun   BookingAdvisorRun @relation(fields: [advisorRunId], references: [id], onDelete: Cascade)
  operator     Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@unique([advisorRunId, operatorId])
  @@index([advisorRunId])
}

model TelegramRegistrationToken {
  id                    String    @id @default(cuid())
  artistId              String
  createdByOperatorId   String
  tokenHash             String    @unique
  expiresAt             DateTime
  consumedAt            DateTime?
  boundChatId           String?
  createdAt             DateTime  @default(now())
  artist                Artist    @relation(fields: [artistId], references: [id], onDelete: Cascade)
  createdBy             Operator  @relation("TelegramRegistrationCreator", fields: [createdByOperatorId], references: [id], onDelete: Cascade)

  @@index([artistId])
  @@index([expiresAt])
}

model TelegramUrgentDedupe {
  id        String   @id @default(cuid())
  artistId  String
  dedupeKey String
  sentAt    DateTime @default(now())
  lastError String?
  artist    Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@unique([artistId, dedupeKey])
  @@index([artistId])
}

model ArtistMembershipInvite {
  id                  String                 @id @default(cuid())
  artistId            String
  email               String
  role                ArtistMembershipRole   @default(member)
  tokenHash           String                 @unique
  status              MembershipInviteStatus @default(pending)
  expiresAt           DateTime
  createdAt           DateTime               @default(now())
  createdByOperatorId String
  acceptedAt          DateTime?
  acceptedOperatorId  String?
  revokedAt           DateTime?
  deliveredAt         DateTime?
  deliveryChannel     InviteDeliveryChannel @default(none)
  deliveryLastError   String?
  artist              Artist                 @relation(fields: [artistId], references: [id], onDelete: Cascade)
  createdBy           Operator               @relation("InviteCreator", fields: [createdByOperatorId], references: [id], onDelete: Cascade)
  acceptedBy          Operator?              @relation("InviteAcceptor", fields: [acceptedOperatorId], references: [id], onDelete: SetNull)

  @@index([artistId])
  @@index([artistId, email])
}

model Venue {
  id          String               @id @default(cuid())
  artistId    String
  name        String
  city        String
  region      String?
  country     String?
  addressLine String?
  lat         Float?
  lng         Float?
  driveMinutesFromBase Int?
  fitScore    Int?
  capacity    Int?
  notes       String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  artist      Artist               @relation(fields: [artistId], references: [id], onDelete: Cascade)
  contacts    Contact[]
  opportunities BookingOpportunity[]
  bookingProspects BookingProspect[]
}

model Contact {
  id          String    @id @default(cuid())
  artistId    String
  venueId     String?
  contactKind ContactKind @default(general)
  fullName    String
  role        String?
  email       String?
  phone       String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  artist      Artist    @relation(fields: [artistId], references: [id], onDelete: Cascade)
  venue       Venue?    @relation(fields: [venueId], references: [id], onDelete: SetNull)
  commandRuns CommandRun[]
  bookingProspects BookingProspect[]
  campaignRecipients BookingCampaignRecipient[]
}

model BookingOpportunity {
  id             String       @id @default(cuid())
  artistId       String
  venueId        String?
  title          String
  stage          BookingStage @default(target)
  targetDate     DateTime?
  marketNotes    String?
  sourceSystem   String?
  sourceRef      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  artist         Artist       @relation(fields: [artistId], references: [id], onDelete: Cascade)
  venue          Venue?       @relation(fields: [venueId], references: [id], onDelete: SetNull)
  tasks          Task[]
  approvals      ApprovalRequest[]
  commandRuns    CommandRun[]
  bookingProspects BookingProspect[]
  campaignRecipients BookingCampaignRecipient[]
}

model Task {
  id             String        @id @default(cuid())
  artistId       String
  opportunityId  String?
  title          String
  status         TaskStatus    @default(todo)
  ownerLabel     String?
  dueAt          DateTime?
  checklist      Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  artist         Artist        @relation(fields: [artistId], references: [id], onDelete: Cascade)
  opportunity    BookingOpportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  bookingCampaignFollowUpFor BookingCampaignRecipient? @relation("CampaignRecipientFollowUpTask")
}

model ArtistBookingProfile {
  id                String   @id @default(cuid())
  artistId          String   @unique
  homeCity          String?
  homeRegion        String?
  homeCountry       String?
  genres            String[] @default([])
  targetCapacityMin Int?
  targetCapacityMax Int?
  bookingPitch      String?
  pressKitUrl       String?
  liveVideoUrl      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  artist            Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
}

model BookingProspect {
  id             String                @id @default(cuid())
  artistId       String
  kind           BookingProspectKind
  status         BookingProspectStatus @default(discovered)
  name           String
  city           String
  region         String?
  country        String?
  capacity       Int?
  websiteUrl     String?
  notes          String?
  sourceSystem   String?
  sourceRef      String?
  sourceMetadata Json?
  venueId        String?
  contactId      String?
  opportunityId  String?
  marketSprintId String?
  convertedAt    DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  artist         Artist                @relation(fields: [artistId], references: [id], onDelete: Cascade)
  venue          Venue?                @relation(fields: [venueId], references: [id], onDelete: SetNull)
  contact        Contact?              @relation(fields: [contactId], references: [id], onDelete: SetNull)
  opportunity    BookingOpportunity?   @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  marketSprint   BookingMarketSprint?  @relation(fields: [marketSprintId], references: [id], onDelete: SetNull)
  campaignRecipients BookingCampaignRecipient[]

  @@unique([artistId, sourceSystem, sourceRef])
  @@index([artistId, status])
  @@index([artistId, updatedAt])
  @@index([marketSprintId, status])
}

model BookingMarketSprint {
  id                    String                   @id @default(cuid())
  artistId              String
  name                  String
  city                  String
  region                String?
  country               String?
  targetDateWindowStart DateTime?
  targetDateWindowEnd   DateTime?
  targetQualifiedCount  Int?
  targetOutreachCount   Int?
  targetBookedCount     Int?
  status                BookingMarketSprintStatus @default(draft)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  artist                Artist                   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  prospects             BookingProspect[]
  campaigns             BookingCampaign[]

  @@index([artistId, status])
  @@index([artistId, updatedAt])
}

model BookingCampaign {
  id                  String                @id @default(cuid())
  artistId            String
  name                String
  status              BookingCampaignStatus @default(draft)
  dateWindowStart     DateTime?
  dateWindowEnd       DateTime?
  subjectTemplate     String
  bodyTemplate        String
  defaultFollowUpDays Int                   @default(7)
  deliveryMode        BookingCampaignDeliveryMode @default(draft_only)
  aiAutomationEnabled Boolean @default(false)
  marketSprintId      String?
  approvalRequestId   String?               @unique
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  artist              Artist                @relation(fields: [artistId], references: [id], onDelete: Cascade)
  marketSprint        BookingMarketSprint?  @relation(fields: [marketSprintId], references: [id], onDelete: SetNull)
  approvalRequest     ApprovalRequest?      @relation("CampaignApproval", fields: [approvalRequestId], references: [id], onDelete: SetNull)
  recipients          BookingCampaignRecipient[]

  @@index([artistId, status])
  @@index([artistId, updatedAt])
  @@index([marketSprintId, status])
}

model BookingCampaignRecipient {
  id             String                         @id @default(cuid())
  campaignId     String
  prospectId     String
  contactId      String?
  opportunityId  String?
  status         BookingCampaignRecipientStatus @default(needs_contact)
  outcomeNote    String?
  outcomeKind    String?
  followUpDueAt  DateTime?
  followUpTaskId String?                        @unique
  createdAt      DateTime                       @default(now())
  updatedAt      DateTime                       @updatedAt
  campaign       BookingCampaign                @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  prospect       BookingProspect                @relation(fields: [prospectId], references: [id], onDelete: Restrict)
  contact        Contact?                       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  opportunity    BookingOpportunity?            @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  followUpTask   Task?                          @relation("CampaignRecipientFollowUpTask", fields: [followUpTaskId], references: [id], onDelete: SetNull)
  deliveries     BookingCampaignDelivery[]

  @@unique([campaignId, prospectId])
  @@index([campaignId, status])
  @@index([followUpDueAt])
}

model BookingCampaignDelivery {
  id          String                        @id @default(cuid())
  artistId    String
  approvalId  String
  recipientId String
  status      BookingCampaignDeliveryStatus @default(pending)
  providerMessageId String?
  error       String?
  attemptedAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime                      @default(now())
  updatedAt   DateTime                      @updatedAt
  artist      Artist                        @relation(fields: [artistId], references: [id], onDelete: Cascade)
  approval    ApprovalRequest               @relation(fields: [approvalId], references: [id], onDelete: Cascade)
  recipient   BookingCampaignRecipient      @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@unique([approvalId, recipientId])
  @@index([artistId, status])
  @@index([recipientId])
}

model ApprovalRequest {
  id             String          @id @default(cuid())
  artistId       String
  opportunityId  String?
  title          String
  status         ApprovalStatus  @default(proposed)
  actionType     String
  payload        Json
  proposedBy     String?
  approvedBy     String?
  approvedAt     DateTime?
  executionAttemptedAt DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  artist         Artist          @relation(fields: [artistId], references: [id], onDelete: Cascade)
  opportunity    BookingOpportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  bookingCampaign BookingCampaign? @relation("CampaignApproval")
  campaignDeliveries BookingCampaignDelivery[]
}

model AuditEvent {
  id               String        @id @default(cuid())
  artistId         String?
  severity         AuditSeverity @default(info)
  aggregateType    String
  aggregateId      String
  action           String
  actorLabel       String?
  actorOperatorId  String?
  metadata         Json
  createdAt        DateTime      @default(now())
  actorOperator    Operator?     @relation(fields: [actorOperatorId], references: [id], onDelete: SetNull)

  @@index([aggregateType, aggregateId])
  @@index([artistId, createdAt])
  @@index([actorOperatorId])
}

model CommandRun {
  id             String      @id @default(cuid())
  artistId       String
  opportunityId  String?
  contactId      String?
  rawInput       String
  intent         String?
  resolvedAction Json
  dryRun         Boolean     @default(true)
  status         String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  artist         Artist      @relation(fields: [artistId], references: [id], onDelete: Cascade)
  opportunity    BookingOpportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  contact        Contact?    @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([artistId, createdAt])
}

model IntegrationConnection {
  id               String   @id @default(cuid())
  artistId         String
  provider         String
  accountLabel     String?
  scopes           String[]
  status           String
  encryptedSecrets Json?
  lastSyncedAt     DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  artist           Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@unique([artistId, provider])
}

model WorkflowNotification {
  id                    String                   @id @default(cuid())
  artistId              String
  recipientOperatorId   String
  kind                  WorkflowNotificationKind
  title                 String
  body                  String
  readAt                DateTime?
  metadata              Json                     @default("{}")
  createdAt             DateTime                 @default(now())
  artist                Artist                   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  recipient             Operator                 @relation(fields: [recipientOperatorId], references: [id], onDelete: Cascade)

  @@index([recipientOperatorId, artistId, readAt])
  @@index([artistId, createdAt])
}
